{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Raskladka Fix",
  "version": "0.1.0",
  "identifier": "com.raskladka.fix",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "title": "Raskladka Fix — Налаштування",
        "width": 480,
        "height": 520,
        "resizable": false,
        "visible": false,
        "center": true,
        "decorations": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Raskladka Fix"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": "uk-UA"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perUser"
      }
    }
  },
  "plugins": {}
}