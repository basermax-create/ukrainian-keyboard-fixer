{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Raskladka Fix",
  "version": "0.1.1",
  "identifier": "com.raskladka.fix",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "title": "Raskladka Fix — Налаштування",
        "width": 480,
        "height": 520,
        "resizable": false,
        "visible": false,
        "center": true,
        "decorations": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Ukrainian", "English"],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {}
}